{
  "name": "betalife-engine",
  "version": "0.1.0",
  "description": "BetaLife soul engine — Layer 1 (14-axis NPC generation)",
  "main": "dist/engine/index.js",
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/runtime/browser.ts --bundle --format=esm --outfile=preview/engine.bundle.js",
    "build:slice": "ts-node --project tsconfig.json scripts/buildSlice.ts",
    "test": "ts-node --project tsconfig.json scripts/testEngine.ts",
    "test:live": "ts-node --project tsconfig.json scripts/testLive.ts"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "@types/node": "^20.14.0",
    "esbuild": "^0.21.5"
  }
}

# Godot 4.2+ specific ignores
~*.dll

# Godot 4+ specific ignores
.godot/
.nomedia

# Godot-specific ignores
.import/
export.cfg
export_credentials.cfg
*.tmp

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# Local git worktrees (scratch isolation for agent-driven implementation work)
.worktrees/

# Godot engine binary (not project source — lives in the repo root for convenience,
# never committed; see CLAUDE.md for the canonical path)
/Godot_v4.7-stable_win64.exe/

# Office lock files
~$*

# GdUnit4 generated test reports
reports/

# Secrets — never commit these
.env
.env.*
*.pem
*.key
*serviceaccount*.json
*service-account*.json
firebase-debug.log

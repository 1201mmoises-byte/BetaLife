; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GodotGame"
run/main_scene="res://scenes/dev/dev_panel.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[editor_plugins]

enabled=PackedStringArray("res://addons/gdUnit4/plugin.cfg", "res://addons/gaea/plugin.cfg", "res://addons/godot-sqlite/plugin.cfg")

[gui]

theme/custom="res://assets/ui/betalife_theme.tres"

[rendering]

environment/defaults/default_clear_color=Color(0.114, 0.098, 0.086, 1)
